{
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.7.0"
    }
  },
  "routes": [
    {
      "src": "/img/(.*)",
      "dest": "/img/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/indexC.php"
    },
     {
      "src": "/(.*)",
      "dest": "/indexM.php"
    }
  ]
}
